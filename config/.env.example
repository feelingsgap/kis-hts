# KIS 자격증명 템플릿 (auto-trading config/{vps,prod} 패턴)
# 실제 파일은 config/vps/.env (모의) · config/prod/.env (실전) 에 두며 git 커밋 금지(.gitignore).
# 백엔드가 KIS_HTS_ENV(vps|prod)에 따라 config/{env}/.env 를 로드해 사용. 기본 vps(모의).
# 토큰 파일 캐시는 ~/KIS/config/ 에 그대로 저장됨(env별 계좌번호로 자연 분리).

KIS_APP_KEY=여기에_앱키
KIS_APP_SECRET=여기에_앱시크릿
KIS_ACCT=12345678        # 계좌번호 앞 8자리 (CANO)
KIS_HTS_ID=여기에_HTS_ID  # 체결통보/조건검색용
KIS_PROD=01              # 계좌 상품코드 2자리 (01=종합/주식)
