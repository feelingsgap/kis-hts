# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# KIS 자격증명 (repo 내 관리, 커밋 금지). config/.env.example 템플릿만 커밋.
.env
config/vps/.env
config/prod/.env
!config/.env.example

# uv
.uv/

# Node / Tauri
node_modules/
frontend/dist/
frontend/src-tauri/target/
# 백엔드 동결 산출물 + Tauri에 동봉되는 sidecar 바이너리(빌드 아티팩트)
backend/packaging/build/
backend/packaging/dist/
backend/packaging/*.log
# resources/ 내용물은 무시하되, tauri 빌드가 디렉터리를 찾도록 .gitkeep만 추적
frontend/src-tauri/resources/*
!frontend/src-tauri/resources/backend/
frontend/src-tauri/resources/backend/*
!frontend/src-tauri/resources/backend/.gitkeep

# 로컬 데이터
*.sqlite
*.db

# 토큰 파일 캐시는 ~/KIS/config/ 에 저장 (repo 밖)

# macOS
.DS_Store

# IDE
.vscode/
.idea/
